{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "backend/api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/health",
      "dest": "backend/api/index.ts"
    },
    {
      "src": "/auth/(.*)",
      "dest": "backend/api/index.ts"
    },
    {
      "src": "/tasks/(.*)",
      "dest": "backend/api/index.ts"
    },
    {
      "src": "/tasks",
      "dest": "backend/api/index.ts"
    },
    {
      "src": "/focus/(.*)",
      "dest": "backend/api/index.ts"
    },
    {
      "src": "/notes/(.*)",
      "dest": "backend/api/index.ts"
    },
    {
      "src": "/finance/(.*)",
      "dest": "backend/api/index.ts"
    },
    {
      "src": "/wellness/(.*)",
      "dest": "backend/api/index.ts"
    },
    {
      "src": "/coach/(.*)",
      "dest": "backend/api/index.ts"
    },
    {
      "src": "/analytics/(.*)",
      "dest": "backend/api/index.ts"
    },
    {
      "src": "/blocklist/(.*)",
      "dest": "backend/api/index.ts"
    },
    {
      "src": "/academic/(.*)",
      "dest": "backend/api/index.ts"
    },
    {
      "src": "/api/backend/(.*)",
      "dest": "backend/api/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ]
}
