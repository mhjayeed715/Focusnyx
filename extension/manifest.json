{
  "manifest_version": 3,
  "name": "Focusnyx Focus Lock",
  "version": "0.1.0",
  "description": "Blocks distraction sites during active Pomodoro sessions and logs attempts.",
  "permissions": ["storage", "tabs", "declarativeNetRequest", "declarativeNetRequestWithHostAccess"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "dist/background/service-worker.js"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Focusnyx"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
